{
  "module": {
    "auth_1033": {
      "source": "git::https://gitlab.com/pl.rachuna-net/artifacts/opentofu/proxmox-container.git?ref=v1.0.3",
      "hostname": "auth-1033.rachuna-net.pl",
      "description": "gitlab-runner s4",
      "node_name": "pve-s4",
      "ct_id": 1033,
      "pool_id": "sql",
      "protection": true,
      "start_on_boot": true,
      "tags": ["auth", "authentik", "ubuntu"],
      "unprivileged": false,
      "is_dmz": true,
      "cpu_cores": 2,
      "mac_address": "BC:24:11:F5:9D:34",
      "memory": {
        "dedicated": 2048,
        "swap": 0
      },
      "disk": {
        "storage_name": "storage",
        "disk_size": 16
      },
      "operating_system": {
        "template_file": "${join(\"/\", [local.ct_storage_name, \"ubuntu-24.04.tar.zst\"])}",
        "type": "ubuntu"
      },
      "features": {
        "keyctl": true,
        "nesting": true
      },
      "user_account": {
        "username": "${local.user_account.username}",
        "password": "${local.user_account.password}",
        "public_ssh_key": "${local.user_account.public_ssh_key}"
      }
    }
  },
  "resource": {
    "vault_kv_secret_v2": {
      "auth-1033_credentials": {
        "mount": "pl.rachuna-net",
        "name": "infrastructure/pve-rachuna-net/iac-proxmox/machine/1033",
        "data_json": "${jsonencode({root_password = module.auth_1033.root_password, root_private_key = module.auth_1033.root_private_key, root_public_key = module.auth_1033.root_public_key, container_ipv4 = module.auth_1033.container_ipv4})}"
      }
    }
  }
}
