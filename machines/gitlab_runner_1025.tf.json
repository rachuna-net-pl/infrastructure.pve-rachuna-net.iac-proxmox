{
  "module": {
    "gitlab_runner_1025": {
      "source": "git::https://gitlab.com/pl.rachuna-net/artifacts/opentofu/proxmox-container.git?ref=v1.0.3",
      "hostname": "gitlab-runner-1025.rachuna-net.pl",
      "description": "gitlab-runner s1",
      "node_name": "pve-s1",
      "ct_id": 1025,
      "pool_id": "gitlab",
      "protection": true,
      "start_on_boot": true,
      "tags": ["gitlab-runner", "ubuntu"],
      "unprivileged": false,
      "is_dmz": true,
      "mac_address": "BC:24:11:0F:BD:60",
      "cpu_cores": 4,
      "memory": {
        "dedicated": 4096,
        "swap": 0
      },
      "disk": {
        "storage_name": "storage",
        "disk_size": 128
      },
      "operating_system": {
        "template_file": "${join(\"/\", [local.ct_storage_name, \"ubuntu-24.04.tar.zst\"])}",
        "type": "ubuntu"
      },
      "features": {
        "keyctl": true,
        "nesting": true
      },
      "user_account": {
        "username": "${local.user_account.username}",
        "password": "${local.user_account.password}",
        "public_ssh_key": "${local.user_account.public_ssh_key}"
      }
    }
  },
  "resource": {
    "vault_kv_secret_v2": {
      "gitlab_runner_1025_credentials": {
        "mount": "pl.rachuna-net",
        "name": "infrastructure/pve-rachuna-net/iac-proxmox/machine/1024",
        "data_json": "${jsonencode({root_password = module.gitlab_runner_1025.root_password, root_private_key = module.gitlab_runner_1025.root_private_key, root_public_key = module.gitlab_runner_1025.root_public_key, container_ipv4 = module.gitlab_runner_1025.container_ipv4})}"
      }
    }
  }
}
